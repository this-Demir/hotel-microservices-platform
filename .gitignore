# ============================================================
# .NET / ASP.NET Core
# ============================================================
[Bb]in/
[Oo]bj/
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
*.DotSettings.user
publish/
*.nupkg
*.snupkg
*.log

# EF Core migrations snapshots are committed; compiled output is not
# (keep Migrations/ tracked, ignore obj inside it)

# ============================================================
# AWS Lambda
# ============================================================
src/cron-jobs/*.zip

# ============================================================
# Node / Next.js (frontend-client)
# ============================================================
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================================
# Environment & Secrets
# ============================================================
.env
.env.*
!.env.example

# All environment-specific appsettings (Development, Staging, Production, Local, etc.)
# Base appsettings.json (placeholder values only) remains tracked.
appsettings.*.json

# .NET user secrets
secrets.json

# Certificates & private keys — never commit these
*.pfx
*.p12
*.pem
*.key
*.crt
*.cer

# npm auth tokens
.npmrc

# launchSettings.json carries environmentVariables — safe to commit only if it has no secrets.
# If you add API keys under environmentVariables, move them to appsettings.Development.json instead.

# ============================================================
# Docker
# ============================================================
docker-compose.override.yml

# ============================================================
# OS
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# IDEs
# ============================================================
.idea/
.vscode/
*.swp
*.swo

# ============================================================
# Claude Code
# ============================================================
.claude/
.mcp.json
